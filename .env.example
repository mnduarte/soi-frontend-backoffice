# SOI backoffice (super-admin console) — environment variables
# Copy to `.env` for local dev. On Vercel set via Project Settings → Env vars.

# URL of the SOI backend API (NestJS).
#   Local: http://localhost:30400
#   Prod:  https://<your-fly-app>.fly.dev  (or your custom domain)
VITE_API_URL=http://localhost:30400

# URL of the clinic-facing app — used by the "Impersonate" button to open
# the dentist app in a new tab with the signed JWT.
#   Local: http://localhost:5173
#   Prod:  https://<your-core-app>.vercel.app  (or your custom domain)
VITE_CORE_APP_URL=http://localhost:5173
